---
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/contact", label: "Contact" },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-semibold tracking-tight" style="font-family:'Playfair Display',serif; color:#1a3a2a;">
      Law Fern
    </a>
    <ul class="flex gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`text-sm font-medium transition-colors hover:text-[#3d7a56] ${
              current === href ? "text-[#3d7a56] border-b-2 border-[#3d7a56] pb-0.5" : "text-gray-600"
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
