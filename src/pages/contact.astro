---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": "Law Fern",
  "url": "https://lawfern.co.uk/contact",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "hello@lawfern.co.uk",
    "availableLanguage": "English",
  },
};
---

<Layout
  title="Contact — Law Fern"
  description="Get in touch with Law Fern for a free initial consultation. No obligation, no jargon."
  schema={schema}
>
  <Nav />

  <main class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-semibold text-[#1a3a2a] mb-4">Get in touch</h1>
    <p class="text-gray-600 mb-10">
      We offer a free initial consultation — no obligation, no pressure. Tell us what you're dealing with and we'll tell you honestly how we can help.
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      class="space-y-6"
    >
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full border border-gray-300 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#3d7a56] focus:border-transparent"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full border border-gray-300 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#3d7a56] focus:border-transparent"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">How can we help?</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-gray-300 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#3d7a56] focus:border-transparent resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full bg-[#3d7a56] text-white py-3 rounded-md font-medium hover:bg-[#1a3a2a] transition-colors"
      >
        Send message
      </button>
    </form>

    <p class="text-center text-sm text-gray-400 mt-8">
      Or email us directly at <a href="mailto:hello@lawfern.co.uk" class="text-[#3d7a56] hover:underline">hello@lawfern.co.uk</a>
    </p>
  </main>

  <Footer />
</Layout>
