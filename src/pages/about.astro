---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": "Law Fern",
  "description": "About Law Fern — a law firm committed to clear, honest legal advice.",
  "url": "https://lawfern.co.uk/about",
};
---

<Layout
  title="About — Law Fern"
  description="Law Fern is a law firm built around honest advice, transparent pricing, and human connection."
  schema={schema}
>
  <Nav />

  <main class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-semibold text-[#1a3a2a] mb-6">About Law Fern</h1>
    <p class="text-lg text-gray-600 leading-relaxed mb-6">
      Law Fern was founded on a simple belief: legal advice should be clear, accessible, and honest. Too many people avoid legal help because it feels intimidating or expensive — we're here to change that.
    </p>
    <p class="text-gray-600 leading-relaxed mb-6">
      We work with individuals and small businesses across the UK, providing practical guidance on a wide range of legal matters. Our approach is always personal — you'll always speak with a qualified solicitor who takes the time to understand your situation.
    </p>
    <p class="text-gray-600 leading-relaxed">
      Whether you're facing a dispute, need a contract reviewed, or just want to understand your rights, Law Fern is here to help.
    </p>

    <div class="mt-12 p-6 bg-[#f8f5f0] rounded-lg border-l-4 border-[#3d7a56]">
      <p class="text-[#1a3a2a] font-medium">"We believe everyone deserves access to clear, honest legal advice — not just those who can afford a big city firm."</p>
    </div>
  </main>

  <Footer />
</Layout>
